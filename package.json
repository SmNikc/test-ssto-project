{
  "name": "test-ssto-monorepo",
  "private": true,
  "workspaces": ["frontend", "backend-nest"],
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm -w backend-nest run build",
    "build:frontend": "npm -w frontend run build",

    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm -w backend-nest test",
    "test:frontend": "npm -w frontend test",

    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm -w backend-nest run lint",
    "lint:frontend": "npm -w frontend run lint"
  },
  "engines": { "node": ">=18.18.0" }
}
