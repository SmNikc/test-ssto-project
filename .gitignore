# Node.js, TypeScript, Angular, React, Vite
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# Сборочные артефакты (корень и любые вложенные пакеты)
dist/
**/dist/
build/
**/build/
.angular/
.vite/
.cache/
.sass-cache/

# Python, Pytest, Coverage
__pycache__/
*.pyc
.pytest_cache/
.nyc_output/
.coverage
.coverage.*
.cache/
*.pyo

# IDE и служебные файлы
.idea/
.vscode/
*.swp
*.swo
*.bak
*.tmp

# System, OS-specific
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?

# Архивы
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Базы данных, дампы, артефакты
*.sqlite
*.db
*.sql
*.dump

# Сборочные/исполняемые файлы
*.exe
*.dll
*.so
*.obj
*.out

# Документы, медиа (если не исходники)
*.png
*.jpg
*.jpeg
*.ico
*.gif
*.pdf
*.docx
*.xlsx
*.xls
*.pptx
*.csv
