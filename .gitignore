*.mov
*.wav
*.tif

# Конфиги среды/локальные
.env
.env.*
local.settings.json

# Исключения для шаблонов env и других важных файлов
!backend-nest/.env.example
!frontend/.env.example
!backend-nest/.env.sample
!frontend/.env.sample
!backend-nest/.env.dist
!frontend/.env.dist

# Исключения для шаблонов миграций и инструкций
!docs/
!README.md
!migrations/
!backend-nest/docs/
!frontend/docs/

# Временные файлы/скрипты в корне (если нужны — удалите этот блок)
scripts/*
!scripts/README.md
temp/
*.bak
*.tmp
test-*.js
clean-*.js
fix-*.js
